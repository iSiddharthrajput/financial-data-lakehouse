# ─────────────────────────────────────────────────────────────
# 📊 Financial Data Lakehouse — Local Environment Secrets
# ─────────────────────────────────────────────────────────────
# Copy this file to '.env' and populate with your own credentials:
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ❄️ Snowflake Data Warehouse Credentials
SNOWFLAKE_ACCOUNT=your_snowflake_account_locator
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=your_snowflake_role
SNOWFLAKE_WAREHOUSE=your_snowflake_warehouse
SNOWFLAKE_DATABASE=FINANCIAL_LAKEHOUSE

# 📰 News API Credentials
# Get a free API key at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_org_api_key

# 🌀 Apache Airflow Settings
# On Linux/macOS, set to: AIRFLOW_UID=$(id -u)
# On Windows, default 50000 is usually fine
AIRFLOW_UID=50000
